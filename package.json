{
  "name": "confchain",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @confchain/api dev",
    "dev:web": "pnpm --filter @confchain/web dev",
    "dev:api": "pnpm --filter @confchain/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down"
  }
}
