MYSQL_ROOT_PASSWORD=confchain_root
MYSQL_DATABASE=confchain
MYSQL_USER=confchain
MYSQL_PASSWORD=confchain
DATABASE_URL=mysql://confchain:confchain@localhost:3306/confchain

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---------- 后端与 WeBASE / FISCO 交互（需你提供） ----------
# WeBASE-Front 服务地址（含 /WeBASE-Front）
WEBASE_FRONT_URL=http://192.168.229.130:5002/WeBASE-Front
# 发交易时使用的 WeBASE 用户：优先填「用户地址」0x...（推荐，符合官方 /trans/handle 要求），否则填 WeBASE 用户名如 admin1
WEBASE_SIGN_USER_ADDRESS=0x30bb0ddb899eafac020b495df5bb41904f903257
WEBASE_SIGN_USER=admin1
# 群组 ID，与浏览器访问路径一致（如 .../group0/web3/blockNumber 则填 group0）
FISCO_GROUP_ID=group0
# 链 ID，仅展示用
FISCO_CHAIN_ID=20200
# 版权合约 / 审稿合约地址（WeBASE 部署后复制）
FISCO_CONTRACT_COPYRIGHT=0xc8ead4b26b2c6ac14c9fd90d9684c9bc2cc40085
FISCO_CONTRACT_REVIEW=0xc8ead4b26b2c6ac14c9fd90d9684c9bc2cc40085
# FISCO 节点 RPC（可选，当前主要用于文档/扩展）
FISCO_RPC_URL=http://192.168.229.130:20200
